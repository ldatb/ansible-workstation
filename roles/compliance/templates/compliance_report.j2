  {% endif %}
  {% if security_updates.stdout | int > 0 %}
    {% set _ = issues.append('⚠️  ' + security_updates.stdout + ' security update(s) available') %}
  {% endif %}
{% elif ansible_os_family == "RedHat" %}
  {% if firewalld_status.rc != 0 or 'not running' in firewalld_status.stdout | lower %}
    {% set _ = issues.append('❌ Firewalld is not running') %}
  {% endif %}
  {% if selinux_status.stdout | default('') not in ['Enforcing', 'Permissive'] %}
    {% set _ = issues.append('⚠️  SELinux status: ' + selinux_status.stdout | default('Unknown')) %}
  {% endif %}
{% endif %}

