{% elif ansible_os_family == "Debian" %}
  {% if 'inactive' in ufw_status.stdout | lower %}
    {% set _ = issues.append('❌ UFW firewall is inactive') %}
  {% endif %}
  {% if 'yes' in ssh_config.stdout and 'PermitRootLogin yes' in ssh_config.stdout %}
